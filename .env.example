# AI Provider Configuration
# Choose from: ollama, openai, mistral, anthropic
AI_PROVIDER=ollama

# AI Model (optional - defaults to provider's default model)
AI_MODEL=llama3.2

# Generic API key (used if provider-specific key is not set)
# AI_API_KEY=your_api_key_here

# Custom API base URL (optional - for custom endpoints)
# AI_BASE_URL=https://ollama.com

# Request timeout in milliseconds (default: 30000)
# AI_TIMEOUT=30000

# Max retry attempts (default: 3)
# AI_MAX_RETRIES=3

# ============================================================================
# Provider-Specific API Keys
# Use these for better security isolation or when using multiple providers
# ============================================================================

# Ollama (optional - only needed for Ollama Cloud)
# OLLAMA_API_KEY=your_ollama_api_key
# OLLAMA_CLOUD_URL=https://ollama.com

# OpenAI (required if using OpenAI provider)
# OPENAI_API_KEY=sk-your-openai-api-key

# Mistral AI (required if using Mistral provider)
# MISTRAL_API_KEY=your-mistral-api-key

# Anthropic (required if using Anthropic provider)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ============================================================================
# Next.js Configuration
# ============================================================================

# Node environment
NODE_ENV=development

# Next.js public variables (exposed to browser)
# NEXT_PUBLIC_APP_NAME=Resume Builder

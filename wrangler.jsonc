{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "resume-builder",
  "compatibility_date": "2025-09-27",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "main": ".open-next/worker.js",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "build": {
    "command": "bun install && bun run build:cf",
    "cwd": "."
  }
}
